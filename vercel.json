{
  "version": 2,
  "builds": [
    { "src": "frontend/**/*.php", "use": "@vercel/php" },
    { "src": "backend/**/*.php", "use": "@vercel/php" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/frontend/index.php" },
    { "src": "^/backend/(.*)$", "dest": "/backend/$1" },
    { "src": "^/frontend/(.*)$", "dest": "/frontend/$1" },
    { "src": "^/(.*)$", "dest": "/frontend/$1" }
  ]
}
